# Copy to .env.local and fill in to switch from mock mode to real providers.

# --- Speech-to-text (pick one; leave blank to use the mock STT) ---
# AssemblyAI Universal-Streaming — cheapest hosted streaming STT (~$0.15/hr)
ASSEMBLYAI_API_KEY=
# Deepgram Nova-3 streaming (alternative)
DEEPGRAM_API_KEY=

# --- Interesting-moment scoring LLM (leave blank to use the heuristic mock scorer) ---
# When set, transcript windows are scored by Claude (reads slang/sarcasm/context),
# replacing the keyword heuristic entirely.
ANTHROPIC_API_KEY=
# Fast, cheap model for high-frequency scoring (~once / 5s per stream).
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Pipeline tuning (optional; sensible defaults applied) ---
# Seconds of stream kept in the rolling buffer for retroactive clipping
BUFFER_WINDOW_SECONDS=180
# Length of each on-disk segment written by ffmpeg
SEGMENT_SECONDS=4
